generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notice {
  id          Int      @id @default(autoincrement())
  title       String
  body        String
  category    String
  priority    String
  publishDate DateTime
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}